# Telegram Configuration
# Get your bot token from @BotFather on Telegram
VITE_TELEGRAM_BOT_TOKEN=your_bot_token_here

# Get your chat ID from @userinfobot on Telegram
VITE_TELEGRAM_CHAT_ID=your_chat_id_here

# Your email address (for FormSpree or backend)
VITE_SEND_TO_EMAIL=your_email@example.com

# FormSpree Form ID (if using FormSpree for email)
# Sign up at https://formspree.io and create a form
VITE_FORMSPREE_ID=your_formspree_id_here
